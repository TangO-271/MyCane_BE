# ============================================
# MyCane_BE — Satellite Team API (FastAPI)
# Copy to .env and fill in. NEVER commit real secrets.
# Note: the BE also runs the MyCane_DB pipeline in-process,
# so it needs the data-source keys below too.
# ============================================

# --- Database (PostGIS) ---
# Either set DATABASE_URL directly...
DATABASE_URL=postgresql://satellite:dev_password@localhost:5432/geoai
# ...or leave it blank and use these (config.py assembles DATABASE_URL):
POSTGIS_HOST=localhost
POSTGIS_PORT=5432
POSTGIS_DB=geoai
POSTGIS_USER=satellite
POSTGIS_PASSWORD=dev_password

# --- Auth / JWT ---
# Required in any shared/deployed env. If unset, a random per-process key is
# generated and all JWTs are invalidated on restart.
SECRET_KEY=

# --- Object storage (S3 / MinIO) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=satellite-data

# --- Profile image storage (Supabase) ---
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_STORAGE_BUCKET=profiles

# --- LINE (login + messaging push) ---
LINE_CHANNEL_ACCESS_TOKEN=
LINE_LOGIN_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# --- Satellite / pipeline data sources (run in-process) ---
COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=
COPERNICUS_USERNAME=
COPERNICUS_PASSWORD=
FIRMS_MAP_KEY=
TMD_API_KEY=
DEMO_PLOT_LAT=16.82
DEMO_PLOT_LON=100.26

# --- Deployed-API smoke test (api/verify_remote.py) ---
HF_TOKEN=
