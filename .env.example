# ============================================
# MyCane_BE — Satellite Team API (FastAPI)
# Copy to .env and fill in. NEVER commit real secrets.
# The BE and DB pipeline are decoupled — the API does NOT run the pipeline, so it
# needs none of the data-source keys (COPERNICUS / FIRMS / TMD). Those live in
# MyCane_DB/.env.
# ============================================

# --- Database ---
# Supabase Postgres. Use the pooler host. Port 5432 = session mode (≤15 clients);
# 6543 = transaction mode (higher concurrency). See app/core/config.py + app/lifespan.py.
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres

# POSTGIS_* are used ONLY by the one-off maintenance scripts in MyCane_BE/db/
# (import_shapefiles, check_soil, update_old_plots) — NOT by the API (it uses
# DATABASE_URL). Safe to omit if you don't run those scripts.
POSTGIS_HOST=localhost
POSTGIS_PORT=5432
POSTGIS_DB=geoai
POSTGIS_USER=satellite
POSTGIS_PASSWORD=dev_password

# --- DB connection pools (optional — sensible defaults in code) ---
# Keep psycopg2 + SQLAlchemy combined under the Supabase pooler's client limit
# (session mode = 15). Defaults: DB_POOL_MAX=8, SQLALCHEMY_POOL_SIZE=3,
# SQLALCHEMY_MAX_OVERFLOW=2 → ≤13. Raise these on transaction mode (6543).
# DB_POOL_MIN=2
# DB_POOL_MAX=8
# SQLALCHEMY_POOL_SIZE=3
# SQLALCHEMY_MAX_OVERFLOW=2

# --- Auth / JWT ---
# Required in any shared/deployed env. If unset, a random per-process key is
# generated and all JWTs are invalidated on restart.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# --- Object storage (S3 / MinIO) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=satellite-data

# --- Profile image storage (Supabase) ---
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_STORAGE_BUCKET=profiles

# --- LINE (login + messaging push) ---
# Messaging API channel → access token (long-lived) + channel secret.
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
# LINE Login channel → Channel ID (the id_token audience for LIFF login verify).
LINE_LOGIN_CHANNEL_ID=

# --- Deployed-API smoke test (api/verify_remote.py) ---
HF_TOKEN=
